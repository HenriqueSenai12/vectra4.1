-- ==========================================================================
-- BANCO DE DADOS: VECTRA DB
-- ==========================================================================
DROP DATABASE vectra_db;
CREATE DATABASE IF NOT EXISTS vectra_db;

USE vectra_db;

-- ==========================================================================
-- 1. TABELA DE USUÁRIOS
-- ==========================================================================
CREATE TABLE IF NOT EXISTS usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome_completo VARCHAR(100) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    funcao ENUM('admin', 'operador') NOT NULL,
    senha VARCHAR(255) NOT NULL,
    foto_perfil VARCHAR(255) DEFAULT NULL, -- Adicionado para a tela de configurações
    data_registro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ==========================================================================
-- 2. TABELA DE EQUIPAMENTOS (Sistemas/Máquinas monitoradas)
-- ==========================================================================
CREATE TABLE IF NOT EXISTS equipamentos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    status_atual ENUM('online', 'offline', 'manutencao') DEFAULT 'offline',
    ultima_inicializacao DATETIME,
    uptime_minutos INT DEFAULT 0,
    paradas_emergencia_count INT DEFAULT 0,
    data_atualizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- ==========================================================================
-- 3. TABELA DE LOGS DE OPERAÇÃO (Alimenta a Tabela HTML de "Últimos Registros")
-- ==========================================================================
CREATE TABLE IF NOT EXISTS logs_operacao (
    id INT AUTO_INCREMENT PRIMARY KEY,
    equipamento_id INT NOT NULL,
    usuario_id INT NULL,
    tipo_evento ENUM('inicializacao', 'parada_emergencia', 'manutencao', 'operacao_normal') NOT NULL,
    data_inicio DATETIME NOT NULL,
    data_fim DATETIME NULL,
    duracao_minutos INT NULL,
    descricao TEXT,
    FOREIGN KEY (equipamento_id) REFERENCES equipamentos(id) ON DELETE CASCADE,
    FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE SET NULL
);

-- ==========================================================================
-- 4. TABELA DE MÉTRICAS DIÁRIAS (Alimenta os Gráficos ApexCharts)
-- ==========================================================================
CREATE TABLE IF NOT EXISTS metricas_diarias (
    id INT AUTO_INCREMENT PRIMARY KEY,
    equipamento_id INT NOT NULL,
    data_registro DATE NOT NULL,
    inicializacoes_count INT DEFAULT 0,
    paradas_emergencia_count INT DEFAULT 0,
    tempo_operando_minutos INT DEFAULT 0,
    tempo_manutencao_minutos INT DEFAULT 0,
    FOREIGN KEY (equipamento_id) REFERENCES equipamentos(id) ON DELETE CASCADE,
    UNIQUE KEY unique_registro_diario (equipamento_id, data_registro)
);


