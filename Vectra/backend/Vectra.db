-- 5. Tabela Painel Suporte

-- ==========================================================================

CREATE TABLE IF NOT EXISTS publicacoes (

    id INT AUTO_INCREMENT PRIMARY KEY,

    titulo VARCHAR(255) NOT NULL,

    categoria VARCHAR(100) NOT NULL,

    compartilhavel BOOLEAN DEFAULT TRUE, -- 1 para On (True), 0 para Off (False)

    descricao TEXT,

    caminho_arquivo VARCHAR(255), -- Para armazenar a URL ou caminho do arquivo PNG/JPG/PDF enviado

    usuario_id INT NULL, -- Opcional: para registrar quem fez a publicação

    data_publicacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE SET NULL

);


select * from usuarios;





