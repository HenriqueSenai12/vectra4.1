# URL do seu projeto Supabase
SUPABASE_URL="sua_url_do_projeto_aqui"

# Chave pública anônima (segura para usar no frontend)
SUPABASE_ANON_KEY="sua_anon_key_aqui"

# URL de conexão direta com o banco de dados (Necessário apenas se for usar ORMs como Prisma, Drizzle ou Sequelize)
DATABASE_URL="sua_database_url_aqui"